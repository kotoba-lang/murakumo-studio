;; shadow-cljs ビルド設定。frontend は src/murakumo_studio/{desktop,ui,tauri,state}.cljs(c)。
;; 出力は Tauri WebView が読む tauri/dist/js/(tauri/dist/index.html が読み込む)。
{:deps {:aliases [:cljs]}
 :nrepl {:port 9631}

 :builds
 {:app
  {:target :browser
   :output-dir "tauri/dist/js"
   :asset-path "js"
   :modules {:main {:init-fn murakumo-studio.desktop/init!}}
   :devtools {:watch-dir "tauri/dist"}}}}
