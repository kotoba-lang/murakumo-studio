{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "murakumo-studio",
  "version": "0.1.0",
  "identifier": "net.kotoba-lang.murakumo-studio",
  "build": {
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "url": "index.html",
        "title": "murakumo-studio",
        "width": 1080,
        "height": 760,
        "minWidth": 720,
        "minHeight": 480,
        "visible": true,
        "center": true,
        "titleBarStyle": "Visible"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"]
  }
}
